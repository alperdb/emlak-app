{
  "name": "emlak-ofis-yonetim",
  "version": "1.0.0",
  "description": "Emlak Ofisi Yönetim Uygulaması",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron electron.js",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.emlak.ofis",
    "productName": "Emlak Ofisi",
    "files": [
      "electron.js",
      "server.js",
      "db.js",
      "routes/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "emlak.db", "to": "emlak.db", "filter": ["**/*"] }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["tr_TR"],
      "language": "1055"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0"
  }
}
